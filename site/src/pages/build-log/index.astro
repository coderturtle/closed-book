---
import { getCollection } from "astro:content";
import BaseLayout from "../../components/layout/BaseLayout.astro";

const entries = (await getCollection("buildlog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const fmt = (d: Date) =>
  d.toLocaleDateString("en-GB", { year: "numeric", month: "short", day: "numeric" });

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Build log index" description="Every dated entry in the Closed Book build log.">
  <h1 class="text-3xl font-bold">Build log</h1>
  <ul class="mt-6 space-y-4">
    {
      entries.map((entry) => (
        <li>
          <a href={`${base}build-log/${entry.id}/`} class="entry-card">
            <p class="font-mono text-xs uppercase tracking-widest opacity-60">
              {fmt(entry.data.pubDate)}
            </p>
            <p class="entry-title text-xl font-semibold">{entry.data.title}</p>
            <p class="mt-1 text-sm opacity-80">{entry.data.description}</p>
          </a>
        </li>
      ))
    }
  </ul>
</BaseLayout>
